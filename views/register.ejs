<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CCS | Register</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar', { page: page }) %>

  <div class="page-body">
    <div class="auth-card" style="max-width:960px;">

      <!-- Form Side -->
      <div class="auth-form-side">
        <a href="/" class="back-btn">← Back</a>
        <h2 class="auth-title">Sign Up</h2>

        <form id="registerForm" action="/register" method="POST" novalidate>
          <div class="form-grid">

            <div class="form-group full-width" id="grp-idNumber">
              <label for="idNumber">ID Number</label>
              <input type="text" id="idNumber" name="idNumber" placeholder="e.g. 2021-00001">
              <span class="error-msg">ID number is required.</span>
            </div>

            <div class="form-group" id="grp-lastName">
              <label for="lastName">Last Name</label>
              <input type="text" id="lastName" name="lastName" placeholder="Dela Cruz">
              <span class="error-msg">Last name is required.</span>
            </div>

            <div class="form-group" id="grp-firstName">
              <label for="firstName">First Name</label>
              <input type="text" id="firstName" name="firstName" placeholder="Juan">
              <span class="error-msg">First name is required.</span>
            </div>

            <div class="form-group">
              <label for="middleName">Middle Name <span style="font-weight:400;text-transform:none;font-size:0.75rem;">(optional)</span></label>
              <input type="text" id="middleName" name="middleName" placeholder="Santos">
            </div>

            <div class="form-group" id="grp-courseLevel">
              <label for="courseLevel">Course Level / Year</label>
              <input type="number" id="courseLevel" name="courseLevel" placeholder="1" min="1" max="5">
              <span class="error-msg">Course level is required.</span>
            </div>

            <div class="form-group" id="grp-course">
              <label for="course">Course</label>
              <select id="course" name="course">
                <option value="">— Select Course —</option>
                <option value="BSIT">BSIT</option>
                <option value="BSCS">BSCS</option>
                <option value="BSIS">BSIS</option>
                <option value="ACT">ACT</option>
                <option value="Other">Other</option>
              </select>
              <span class="error-msg">Please select a course.</span>
            </div>

            <div class="form-group full-width" id="grp-email">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="juan@example.com">
              <span class="error-msg">A valid email is required.</span>
            </div>

            <div class="form-group" id="grp-password">
              <label for="password">Password</label>
              <input type="password" id="password" name="password" placeholder="••••••••">
              <span class="error-msg">Password must be at least 6 characters.</span>
            </div>

            <div class="form-group" id="grp-confirmPassword">
              <label for="confirmPassword">Confirm Password</label>
              <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••">
              <span class="error-msg" id="confirmMsg">Passwords do not match.</span>
            </div>

            <div class="form-group full-width" id="grp-address">
              <label for="address">Address</label>
              <input type="text" id="address" name="address" placeholder="Street, City, Province">
              <span class="error-msg">Address is required.</span>
            </div>

          </div>

          <button type="submit" class="submit-btn">Register</button>
        </form>

        <p class="auth-link">Already have an account? <a href="/login">Sign in here</a></p>
      </div>

      <!-- Illustration Side -->
      <div class="auth-illus-side">
        <div class="illus-icon">
          <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="12" y="10" width="48" height="52" rx="5" stroke="white" stroke-width="2.5" fill="rgba(255,255,255,0.1)"/>
            <circle cx="36" cy="28" r="9" stroke="white" stroke-width="2.5" fill="rgba(255,255,255,0.15)"/>
            <path d="M20 52c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <circle cx="53" cy="53" r="9" fill="rgba(255,255,255,0.25)" stroke="white" stroke-width="2"/>
            <path d="M50 53h6M53 50v6" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="illus-text">
          <h3>Create Account</h3>
          <p>Register to start monitoring your sit-in sessions at the CCS Laboratory.</p>
        </div>

        <div class="reg-steps">
          <div class="step active" id="step-personal">
            <div class="step-dot"></div>
            <span>Personal Info</span>
          </div>
          <div class="step-line"></div>
          <div class="step" id="step-account">
            <div class="step-dot"></div>
            <span>Account</span>
          </div>
          <div class="step-line"></div>
          <div class="step" id="step-done">
            <div class="step-dot"></div>
            <span>Done</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <style>
    .reg-steps { display:flex; align-items:center; gap:0; margin-top:0.5rem; }
    .step { display:flex; flex-direction:column; align-items:center; gap:0.3rem; font-size:0.78rem; color:rgba(255,255,255,0.5); }
    .step.active { color:rgba(255,255,255,0.95); }
    .step-dot { width:12px; height:12px; border-radius:50%; background:rgba(255,255,255,0.25); border:2px solid rgba(255,255,255,0.4); transition:all 0.3s; }
    .step.active .step-dot { background:white; border-color:white; box-shadow:0 0 10px rgba(255,255,255,0.5); }
    .step.done .step-dot { background:#e8b84b; border-color:#e8b84b; }
    .step-line { width:28px; height:2px; background:rgba(255,255,255,0.2); margin-bottom:1.1rem; }
  </style>

  <script>
    const form = document.getElementById('registerForm');

    const required = [
      { id: 'idNumber',        grp: 'grp-idNumber' },
      { id: 'lastName',        grp: 'grp-lastName' },
      { id: 'firstName',       grp: 'grp-firstName' },
      { id: 'courseLevel',     grp: 'grp-courseLevel' },
      { id: 'course',          grp: 'grp-course' },
      { id: 'email',           grp: 'grp-email' },
      { id: 'password',        grp: 'grp-password' },
      { id: 'confirmPassword', grp: 'grp-confirmPassword' },
      { id: 'address',         grp: 'grp-address' },
    ];

    form.addEventListener('submit', function(e) {
      let valid = true;
      required.forEach(({ id, grp }) => {
        const input = document.getElementById(id);
        const group = document.getElementById(grp);
        let ok = input.value.trim() !== '';
        if (id === 'email' && ok) ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value);
        if (id === 'password' && ok) ok = input.value.length >= 6;
        if (id === 'confirmPassword' && ok) ok = input.value === document.getElementById('password').value;
        if (!ok) { group.classList.add('has-error'); valid = false; }
        else group.classList.remove('has-error');
      });
      if (!valid) e.preventDefault();
    });

    document.querySelectorAll('.form-group input, .form-group select').forEach(el => {
      el.addEventListener('input', function() {
        this.closest('.form-group').classList.remove('has-error');
        checkProgress();
      });
    });

    function updateSteps(state) {
      const steps = ['step-personal','step-account','step-done'];
      const idx = steps.indexOf('step-' + state);
      steps.forEach((s, i) => {
        const el = document.getElementById(s);
        el.classList.remove('active','done');
        if (i < idx) el.classList.add('done');
        else if (i === idx) el.classList.add('active');
      });
    }

    function checkProgress() {
      const personalFilled = ['idNumber','lastName','firstName','courseLevel','course','address'].some(id => document.getElementById(id)?.value.trim());
      const accountFilled  = ['email','password','confirmPassword'].some(id => document.getElementById(id)?.value.trim());
      if (accountFilled) updateSteps('account');
      else if (personalFilled) updateSteps('personal');
    }
  </script>
</body>
</html>
